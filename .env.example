# =====================================================
# VARIÁVEIS DE AMBIENTE - Sistema de Gestão de Metas
# =====================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA comite o .env com dados reais!

# ----------------------------------------------------
# BANCO DE DADOS - Neon PostgreSQL
# ----------------------------------------------------
# Obtenha em: https://console.neon.tech → Connection Details
#
# DATABASE_URL: URL com connection pooling (para a aplicação Next.js)
DATABASE_URL="postgresql://usuario:senha@ep-xxx.regiao.aws.neon.tech/neondb?sslmode=require"

# DIRECT_URL: URL de conexão direta (para Prisma Migrate)
# No Neon: Connection Details → selecione "Pooled connection" e depois "Direct connection"
DIRECT_URL="postgresql://usuario:senha@ep-xxx.regiao.aws.neon.tech/neondb?sslmode=require"
