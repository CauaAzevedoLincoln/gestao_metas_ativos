// Prisma schema - Sistema de Gestão de Metas (PostgreSQL via Neon)
// Prisma 7: URLs de conexão ficam em prisma.config.ts, não aqui.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Meta {
  id          Int      @id @default(autoincrement())
  analista    String
  mesAno      String
  semana      String
  atividade   String
  meta        Float
  realizado   Float
  status      String?
  observacao  String?
  dataCriacao DateTime @default(now())
}
